// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP myXor {
    IN a, b;
    OUT out;

    PARTS:
    //// Replace this comment with your code.
	Nand(a=a,b=b,out=l1);
	Nand(a=a,b=l1,out=l2);
	Nand(a=b,b=l1,out=l3);
	Nand(a=l2,b=l3,out=out);
}
