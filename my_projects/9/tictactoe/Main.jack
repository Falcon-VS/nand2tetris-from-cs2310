class Main {
	function void main() {
		var Board game;
		var boolean currentPlayer, hasWinner;
		let game = Board.create();
		do Output.printString("Player X begins!");
		do Output.println();

		let currentPlayer = false;  // false → X, true → O
		let hasWinner = false;

		while (~hasWinner) {
			do game.takeTurn(currentPlayer);
			let hasWinner = game.checkWinner();
			let currentPlayer = ~currentPlayer; // Switch turn
		}
    return;
	}
}

